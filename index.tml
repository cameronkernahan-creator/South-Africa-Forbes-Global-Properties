<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Voyager Visual × South Africa | Forbes Global Properties</title>
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Montserrat:ital,wght@0,200;0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --black:#0a0a0a;--dark:#111111;--charcoal:#1a1a1a;--slate:#2a2a2a;
  --mid:#666;--light:#999;--cream:#e8e4de;--white:#f5f3ef;--gold:#c9a96e;
  --gold-light:#dbc493;--serif:'Libre Baskerville',Georgia,serif;
  --sans:'Montserrat',-apple-system,sans-serif;
}
html{scroll-behavior:smooth;font-size:16px}
body{background:var(--black);color:var(--white);font-family:var(--sans);
  -webkit-font-smoothing:antialiased;overflow-x:hidden}
::selection{background:var(--gold);color:var(--black)}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;
  padding:1.5rem 3rem;display:flex;justify-content:space-between;align-items:center;
  background:linear-gradient(180deg,rgba(10,10,10,.95) 0%,rgba(10,10,10,0) 100%);
  transition:all .4s}
nav.scrolled{background:rgba(10,10,10,.97);backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(201,169,110,.15)}
.nav-brand{font-family:var(--serif);font-size:1rem;letter-spacing:.15em;
  text-transform:uppercase;color:var(--gold);font-weight:500}
.nav-brand span{color:var(--white);opacity:.6;font-weight:300}
.nav-links{display:flex;gap:2rem}
.nav-links a{color:var(--light);text-decoration:none;font-size:.7rem;
  letter-spacing:.2em;text-transform:uppercase;transition:color .3s}
.nav-links a:hover{color:var(--gold)}

/* HERO */
.hero{height:100vh;display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 30% 50%,rgba(201,169,110,.06) 0%,transparent 60%),
  radial-gradient(ellipse at 70% 30%,rgba(201,169,110,.03) 0%,transparent 50%)}
.hero-content{text-align:center;max-width:900px;padding:0 2rem;position:relative;z-index:1}
.hero-eyebrow{font-size:.65rem;letter-spacing:.4em;text-transform:uppercase;
  color:var(--gold);margin-bottom:2.5rem;font-weight:500}
.hero h1{font-family:var(--serif);font-size:clamp(2.5rem,6vw,5rem);
  font-weight:400;line-height:1.1;color:var(--white);margin-bottom:1.5rem}
.hero h1 em{font-style:italic;color:var(--gold);font-weight:400}
.hero-sub{font-size:1rem;color:var(--light);font-weight:300;line-height:1.8;
  max-width:600px;margin:0 auto 3rem}
.hero-line{width:60px;height:1px;background:var(--gold);margin:0 auto}
.hero-scroll{position:absolute;bottom:3rem;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:.5rem}
.hero-scroll span{font-size:.6rem;letter-spacing:.3em;text-transform:uppercase;
  color:var(--light)}
.scroll-line{width:1px;height:40px;background:linear-gradient(180deg,var(--gold),transparent);
  animation:scrollPulse 2s ease infinite}
@keyframes scrollPulse{0%,100%{opacity:.3;transform:scaleY(.6)}50%{opacity:1;transform:scaleY(1)}}

/* SECTIONS */
section{padding:8rem 3rem;position:relative}
.section-number{font-family:var(--serif);font-size:6rem;font-weight:400;
  color:rgba(201,169,110,.08);position:absolute;top:3rem;right:3rem;line-height:1}
.eyebrow{font-size:.65rem;letter-spacing:.35em;text-transform:uppercase;
  color:var(--gold);margin-bottom:1.5rem;font-weight:500}
.section-title{font-family:var(--serif);font-size:clamp(2rem,4vw,3.2rem);
  font-weight:400;line-height:1.2;margin-bottom:2rem;color:var(--white)}
.section-title em{font-style:italic;color:var(--gold)}
.section-body{font-size:.95rem;line-height:1.9;color:var(--light);
  max-width:680px;font-weight:300}
.section-body+.section-body{margin-top:1.5rem}

/* DIVIDERS */
.gold-rule{width:60px;height:1px;background:var(--gold);margin:4rem 0}
.full-divider{border:none;border-top:1px solid rgba(201,169,110,.15);margin:0}

/* GRID LAYOUTS */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:4rem;margin-top:3rem}
.three-col{display:grid;grid-template-columns:repeat(3,1fr);gap:2.5rem;margin-top:3rem}
@media(max-width:900px){.two-col,.three-col{grid-template-columns:1fr}}

/* CARDS */
.service-card{background:var(--charcoal);border:1px solid rgba(255,255,255,.06);
  padding:2.5rem;position:relative;overflow:hidden;transition:all .4s}
.service-card::before{content:'';position:absolute;top:0;left:0;width:100%;height:2px;
  background:linear-gradient(90deg,var(--gold),transparent);opacity:0;transition:opacity .4s}
.service-card:hover::before{opacity:1}
.service-card:hover{border-color:rgba(201,169,110,.2);transform:translateY(-2px)}
.card-icon{font-size:1.8rem;margin-bottom:1.5rem;opacity:.7}
.card-title{font-family:var(--serif);font-size:1.4rem;font-weight:400;
  color:var(--white);margin-bottom:1rem}
.card-body{font-size:.85rem;line-height:1.8;color:var(--light);font-weight:300}
.card-list{list-style:none;margin-top:1.2rem}
.card-list li{font-size:.82rem;color:var(--light);padding:.4rem 0;
  border-bottom:1px solid rgba(255,255,255,.04);font-weight:300;
  padding-left:1.2rem;position:relative}
.card-list li::before{content:'';position:absolute;left:0;top:50%;
  width:4px;height:4px;background:var(--gold);border-radius:50%;transform:translateY(-50%)}

/* SCOPE TABLE */
.scope-table{width:100%;border-collapse:collapse;margin-top:3rem}
.scope-table th{text-align:left;padding:1rem 1.5rem;font-size:.65rem;
  letter-spacing:.25em;text-transform:uppercase;color:var(--gold);
  border-bottom:1px solid rgba(201,169,110,.3);font-weight:500}
.scope-table td{padding:1rem 1.5rem;font-size:.88rem;color:var(--light);
  border-bottom:1px solid rgba(255,255,255,.04);font-weight:300;vertical-align:top}
.scope-table tr:hover td{color:var(--white);background:rgba(201,169,110,.03)}
.scope-table .label{color:var(--white);font-weight:400}

/* STAT BAR */
.stat-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;margin-top:4rem;
  padding:3rem 0;border-top:1px solid rgba(201,169,110,.15);
  border-bottom:1px solid rgba(201,169,110,.15)}
.stat{text-align:center}
.stat-num{font-family:var(--serif);font-size:2.5rem;font-weight:400;color:var(--gold)}
.stat-label{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;
  color:var(--light);margin-top:.5rem}
@media(max-width:768px){.stat-bar{grid-template-columns:repeat(2,1fr)}}

/* PHASE */
.phase{display:flex;gap:3rem;align-items:flex-start;margin-top:3rem;
  padding:2.5rem 0;border-bottom:1px solid rgba(255,255,255,.04)}
.phase-num{font-family:var(--serif);font-size:3rem;font-weight:400;
  color:var(--gold);min-width:60px;opacity:.6}
.phase-content h3{font-family:var(--serif);font-size:1.5rem;font-weight:400;
  color:var(--white);margin-bottom:.8rem}
.phase-content p{font-size:.88rem;line-height:1.8;color:var(--light);font-weight:300}

/* CTA */
.cta-section{text-align:center;padding:10rem 3rem;position:relative}
.cta-section::before{content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at center,rgba(201,169,110,.05) 0%,transparent 70%)}
.cta-section h2{font-family:var(--serif);font-size:clamp(2rem,5vw,3.5rem);
  font-weight:400;line-height:1.2;margin-bottom:2rem;position:relative}
.cta-section h2 em{font-style:italic;color:var(--gold)}

/* FOOTER */
footer{padding:3rem;text-align:center;border-top:1px solid rgba(201,169,110,.1)}
footer p{font-size:.7rem;letter-spacing:.15em;color:var(--mid);font-weight:300}

/* HIGHLIGHT BOX */
.highlight{background:rgba(201,169,110,.06);border-left:2px solid var(--gold);
  padding:2rem 2.5rem;margin:3rem 0}
.highlight p{font-family:var(--serif);font-size:1.15rem;font-style:italic;
  line-height:1.8;color:var(--cream);font-weight:400}

/* TWO-TIER COMPARE */
.compare{display:grid;grid-template-columns:1fr 1fr;margin-top:3rem;
  border:1px solid rgba(255,255,255,.06)}
.compare-col{padding:2.5rem}
.compare-col:first-child{border-right:1px solid rgba(255,255,255,.06)}
.compare-head{font-size:.65rem;letter-spacing:.25em;text-transform:uppercase;
  color:var(--gold);margin-bottom:1.5rem;font-weight:500}
.compare-col h3{font-family:var(--serif);font-size:1.3rem;color:var(--white);
  margin-bottom:1.2rem;font-weight:400}
@media(max-width:768px){.compare{grid-template-columns:1fr}
  .compare-col:first-child{border-right:none;border-bottom:1px solid rgba(255,255,255,.06)}}

/* ANIMATIONS */
.fade-in{opacity:0;transform:translateY(30px);transition:all .8s cubic-bezier(.16,1,.3,1)}
.fade-in.visible{opacity:1;transform:translateY(0)}
.stagger-1{transition-delay:.1s}.stagger-2{transition-delay:.2s}.stagger-3{transition-delay:.3s}

/* WATERMARK LOGO */
section::after,.hero::after{
  content:'';position:absolute;bottom:2rem;left:3rem;
  width:120px;height:40px;
  background:url('data:image/webp;base64,') no-repeat left center;
  background-size:contain;
  opacity:.15;pointer-events:none;z-index:1
}
.hero::after{bottom:5rem;opacity:.22;width:140px;height:48px}
.cta-section::after{left:50%;transform:translateX(-50%);bottom:3rem;opacity:.12}
</style>
</head>
<body>

<nav id="nav">
  <div class="nav-brand">Voyager Visual <span>× South Africa | Forbes Global Properties</span></div>
  <div class="nav-links">
    <a href="#scope">Scope</a>
    <a href="#services">Services</a>
    <a href="#production">Production</a>
    <a href="#launch">Launch</a>
    <a href="#structure">Structure</a>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-content fade-in">
    <div class="hero-eyebrow">Exclusive Marketing & Production Partnership</div>
    <h1>What <em>Voyager Visual</em> Delivers to<br>South Africa | Forbes Global Properties</h1>
    <p class="hero-sub">A comprehensive overview of the marketing, creative, and production services required to launch and scale South Africa | Forbes Global Properties.</p>
    <div class="hero-line"></div>
  </div>
  <div class="hero-scroll">
    <span>Explore</span>
    <div class="scroll-line"></div>
  </div>
</div>

<hr class="full-divider">

<!-- SECTION 1: THE PARTNERSHIP -->
<section id="scope">
  <span class="section-number">01</span>
  <div class="fade-in">
    <div class="eyebrow">The Partnership</div>
    <h2 class="section-title">Two Services, <em>One Vision</em></h2>
    <p class="section-body">Voyager Visual operates as the exclusive contracted marketing and production partner for South Africa | Forbes Global Properties. This is not a freelance arrangement. It is a white-labeled, equity-aligned partnership delivering both strategic marketing leadership and world-class cinematic production under one roof.</p>
    <p class="section-body">The scope is divided into two distinct service categories, each with its own deliverables, cost structure, and commercial logic. Together, they form the complete creative and operational backbone of the Forbes SA brand.</p>
  </div>

  <div class="compare fade-in">
    <div class="compare-col">
      <div class="compare-head">Service One</div>
      <h3>Marketing Director Retainer</h3>
      <p class="card-body">Full-time strategic marketing leadership. Brand building, social media management, Notion systems, Forbes onboarding, content calendaring, agent recruitment marketing, client experience design, and operational infrastructure. Covered within the monthly retainer.</p>
    </div>
    <div class="compare-col">
      <div class="compare-head">Service Two</div>
      <h3>Film & Content Production</h3>
      <p class="card-body">Cinema-grade property films, listing photography direction, lifestyle content, editorial visuals for Forbes.com, trophy property campaigns, B-roll for launch videos, and ongoing content production for social and digital channels. Billed per project or on a production retainer through Voyager Visual.</p>
    </div>
  </div>

  <div class="highlight fade-in">
    <p>"No Forbes member globally has their marketing director also holding the camera. They all outsource production. By keeping Voyager as the production entity, you get two services through one trusted, equity-aligned partner at below-market rates."</p>
  </div>
</section>

<hr class="full-divider">

<!-- SECTION 2: MARKETING DIRECTOR SCOPE -->
<section id="services">
  <span class="section-number">02</span>
  <div class="fade-in">
    <div class="eyebrow">Marketing Director Scope</div>
    <h2 class="section-title">Strategy, Systems, <em>& Brand</em></h2>
    <p class="section-body">The Marketing Director function covers everything required to build, launch, and scale the Forbes SA brand from zero to market leadership. This is the daily, ongoing strategic work that positions the company as the definitive luxury real estate firm in South Africa.</p>
  </div>

  <div class="three-col">
    <div class="service-card fade-in stagger-1">
      <div class="card-icon">◆</div>
      <div class="card-title">Brand Strategy</div>
      <div class="card-body">
        <ul class="card-list">
          <li>Forbes brand guidelines implementation</li>
          <li>Visual identity and tone of voice</li>
          <li>Company positioning and messaging</li>
          <li>Agent personal brand development</li>
          <li>Brand collateral and templates</li>
          <li>Culture brochure creation</li>
        </ul>
      </div>
    </div>
    <div class="service-card fade-in stagger-2">
      <div class="card-icon">◆</div>
      <div class="card-title">Social Media</div>
      <div class="card-body">
        <ul class="card-list">
          <li>Content calendar (all platforms)</li>
          <li>Instagram, LinkedIn, Facebook, X, YouTube, TikTok, Pinterest</li>
          <li>Keegan's personal brand strategy</li>
          <li>Company account management</li>
          <li>Forbes co-branded templates and Canva assets</li>
          <li>Community engagement and growth</li>
        </ul>
      </div>
    </div>
    <div class="service-card fade-in stagger-3">
      <div class="card-icon">◆</div>
      <div class="card-title">Operations & Systems</div>
      <div class="card-body">
        <ul class="card-list">
          <li>Notion Company OS (full build and management)</li>
          <li>CRM setup and deal pipeline tracking</li>
          <li>Meeting documentation and AI integration</li>
          <li>Roadmap and quarterly milestone planning</li>
          <li>Team coordination and task management</li>
          <li>Investor reporting frameworks</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="three-col" style="margin-top:2rem">
    <div class="service-card fade-in stagger-1">
      <div class="card-icon">◆</div>
      <div class="card-title">Forbes Onboarding</div>
      <div class="card-body">
        <ul class="card-list">
          <li>Portal setup and management</li>
          <li>Company bio and agent profiles</li>
          <li>Listing uploads and API coordination</li>
          <li>Editorial liaison with Forbes editors</li>
          <li>PR firm coordination (NYC)</li>
          <li>Dashboard and marketing tools management</li>
        </ul>
      </div>
    </div>
    <div class="service-card fade-in stagger-2">
      <div class="card-icon">◆</div>
      <div class="card-title">Digital Marketing</div>
      <div class="card-body">
        <ul class="card-list">
          <li>Website strategy and direction</li>
          <li>Email marketing and newsletter setup</li>
          <li>Forbes.com advertising coordination</li>
          <li>Forbes magazine advertising management</li>
          <li>Lead generation and funnel design</li>
          <li>SEO and digital visibility strategy</li>
        </ul>
      </div>
    </div>
    <div class="service-card fade-in stagger-3">
      <div class="card-icon">◆</div>
      <div class="card-title">Growth & Recruitment</div>
      <div class="card-body">
        <ul class="card-list">
          <li>Agent recruitment marketing (postcard, email, events)</li>
          <li>Prospect database management</li>
          <li>5-phase agent onboarding system</li>
          <li>Networking event coordination</li>
          <li>Partnership development (Steadfast, developers)</li>
          <li>Market research and competitive intelligence</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<hr class="full-divider">

<!-- SECTION 3: PRODUCTION -->
<section id="production">
  <span class="section-number">03</span>
  <div class="fade-in">
    <div class="eyebrow">Film & Content Production</div>
    <h2 class="section-title">Cinematic Storytelling <em>at Scale</em></h2>
    <p class="section-body">Every Forbes Global Properties listing must meet the highest visual standards in luxury real estate. Voyager Visual delivers cinema-grade property films, editorial photography direction, and lifestyle content that positions each home not as a listing, but as a story worthy of Forbes.</p>
    <p class="section-body">Production is billed separately because it requires different resources: cinema cameras, professional crews, editing suites, hard drives, lenses, and post-production workflows. This is standard practice across every Forbes GP member globally.</p>
  </div>

  <div class="gold-rule"></div>

  <table class="scope-table fade-in">
    <thead>
      <tr>
        <th style="width:30%">Deliverable</th>
        <th style="width:40%">Description</th>
        <th style="width:30%">Application</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="label">Hero Property Films</td>
        <td>Full cinematic property films (2-4 minutes) shot on Arri Alexa or RED systems with professional crew, scripted narratives, and editorial-grade color grading</td>
        <td>ForbesGlobalProperties.com, Forbes.com, social media, client presentations, magazine submissions</td>
      </tr>
      <tr>
        <td class="label">Listing Photography Direction</td>
        <td>Art direction and quality control for property photography. Minimum 1920x1280, no watermarks, Forbes spec compliance</td>
        <td>Portal listings, carousel images, print materials</td>
      </tr>
      <tr>
        <td class="label">Trophy Property Campaigns</td>
        <td>Full campaign production for marquee listings: film, photography, social assets, editorial visuals, launch materials</td>
        <td>Press releases, Forbes.com features, magazine spreads, social campaigns</td>
      </tr>
      <tr>
        <td class="label">Welcome & Launch Video</td>
        <td>25-second brand welcome video using 3-second B-roll clips of Cape Town, properties, and lifestyle moments</td>
        <td>Forbes launch campaign, website header, social announcement</td>
      </tr>
      <tr>
        <td class="label">Social Content Production</td>
        <td>Short-form video content (Instagram Reels, TikTok, YouTube Shorts), carousel graphics, and story content</td>
        <td>Ongoing social media channels, Forbes co-branded templates</td>
      </tr>
      <tr>
        <td class="label">Lifestyle & Brand Content</td>
        <td>Behind-the-scenes, event coverage, agent profiles, neighbourhood stories, and editorial-style features</td>
        <td>Forbes Visionaries campaign, agent recruitment, brand building</td>
      </tr>
      <tr>
        <td class="label">Aerial & Drone</td>
        <td>Licensed drone cinematography for property exteriors, estates, and coastal locations</td>
        <td>Property films, listing headers, location establishing shots</td>
      </tr>
    </tbody>
  </table>

  <div class="stat-bar fade-in">
    <div class="stat">
      <div class="stat-num">4K+</div>
      <div class="stat-label">Minimum Resolution</div>
    </div>
    <div class="stat">
      <div class="stat-num">R5B</div>
      <div class="stat-label">SA Luxury Market</div>
    </div>
    <div class="stat">
      <div class="stat-num">160M</div>
      <div class="stat-label">Forbes Monthly Visitors</div>
    </div>
    <div class="stat">
      <div class="stat-num">79%</div>
      <div class="stat-label">Global Share of Voice</div>
    </div>
  </div>
</section>

<hr class="full-divider">

<!-- SECTION 4: LAUNCH -->
<section id="launch">
  <span class="section-number">04</span>
  <div class="fade-in">
    <div class="eyebrow">Launch Execution</div>
    <h2 class="section-title">May 15, <em>2026</em></h2>
    <p class="section-body">The Forbes media launch requires a coordinated campaign across press, digital, social, and editorial channels. Every element below falls within Voyager Visual's scope, either as marketing director deliverables or as production items, ensuring a seamless launch experience.</p>
  </div>

  <div class="phase fade-in">
    <div class="phase-num">I</div>
    <div class="phase-content">
      <h3>Pre-Launch (March – April)</h3>
      <p>Contracts finalized. Trophy property secured and filmed. All onboarding items completed. Social accounts live and building audience. Agent profiles and company bio approved on portal. Forbes editorial team briefed. PR firm engaged. B-roll captured for welcome video. Content bank built for launch week.</p>
    </div>
  </div>

  <div class="phase fade-in">
    <div class="phase-num">II</div>
    <div class="phase-content">
      <h3>Launch Week (May 15–16)</h3>
      <p>Press release distributed via Forbes PR firm to Architectural Digest, Financial Times, Robb Report, and local SA media. Social media campaign across Instagram, Facebook, and LinkedIn. 25-second welcome video published. Forbes.com banner (complimentary 2 weeks). Network email to all Forbes GP members globally. Newsletter feature. Portal announcement. Trophy property live on ForbesGlobalProperties.com.</p>
    </div>
  </div>

  <div class="phase fade-in">
    <div class="phase-num">III</div>
    <div class="phase-content">
      <h3>Post-Launch (June onwards)</h3>
      <p>Ongoing content production for new listings. Social media cadence (minimum 3 posts per week per platform). Agent recruitment marketing begins. Editorial submissions to Forbes editors. Magazine advertising coordination. CRM and lead nurturing workflows activated. Quarterly content calendar. Physical launch event planned for November (Cape Town weather optimal).</p>
    </div>
  </div>
</section>

<hr class="full-divider">

<!-- SECTION 5: THE 4P FRAMEWORK -->
<section>
  <span class="section-number">05</span>
  <div class="fade-in">
    <div class="eyebrow">The Methodology</div>
    <h2 class="section-title">Plan, Produce, Publish, <em>Promote</em></h2>
    <p class="section-body">Voyager Visual operates on a proprietary 4P framework that ensures every piece of content moves through a structured pipeline from strategy to measurable outcome. This is not content for content's sake. It is content designed to capture attention, create emotional resonance, and drive commercial results.</p>
  </div>

  <div class="two-col fade-in" style="margin-top:4rem">
    <div>
      <div class="phase" style="border:none;padding-top:0">
        <div class="phase-num">P1</div>
        <div class="phase-content">
          <h3>Plan</h3>
          <p>Strategic alignment before any camera rolls. Target audience profiling, content themes, platform strategy, editorial calendar, Forbes editorial liaison, production budgets, and quarterly milestone mapping.</p>
        </div>
      </div>
      <div class="phase" style="border:none">
        <div class="phase-num">P2</div>
        <div class="phase-content">
          <h3>Produce</h3>
          <p>Cinema-grade execution. Property films, photography direction, lifestyle content, brand storytelling, aerial footage, social assets. Professional crews, editorial color grading, and Forbes-standard deliverables.</p>
        </div>
      </div>
    </div>
    <div>
      <div class="phase" style="border:none;padding-top:0">
        <div class="phase-num">P3</div>
        <div class="phase-content">
          <h3>Publish</h3>
          <p>Multi-platform distribution. Forbes portal listings, ForbesGlobalProperties.com features, social media channels, email newsletters, Forbes.com editorial, magazine placement, and PR distribution.</p>
        </div>
      </div>
      <div class="phase" style="border:none">
        <div class="phase-num">P4</div>
        <div class="phase-content">
          <h3>Promote</h3>
          <p>Amplification and analytics. Forbes.com banner advertising, targeted digital campaigns, agent recruitment outreach, networking events, Forbes magazine features, and performance reporting.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<hr class="full-divider">

<!-- SECTION 6: TEAM -->
<section>
  <span class="section-number">06</span>
  <div class="fade-in">
    <div class="eyebrow">The Team</div>
    <h2 class="section-title">Three People, <em>One Retainer</em></h2>
    <p class="section-body">The Voyager Visual partnership delivers not just a marketing director, but a full creative team. An assistant editor handles day-to-day content processing and social media assets. A production coordinator manages shoot logistics, equipment, and crew. Cameron leads strategy, creative direction, and client-facing execution. All three operate within the existing retainer structure at no additional headcount cost to Forbes SA.</p>
  </div>

  <div class="three-col fade-in" style="margin-top:3rem">
    <div class="service-card" style="text-align:center">
      <div class="card-title">Cameron Kernahan</div>
      <p class="card-body" style="font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem">Marketing Director & Creative Lead</p>
      <p class="card-body">Brand strategy, Forbes liaison, social media direction, systems architecture, client presentations, content oversight, production creative direction</p>
    </div>
    <div class="service-card" style="text-align:center">
      <div class="card-title">Assistant Editor</div>
      <p class="card-body" style="font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem">Post-Production & Content</p>
      <p class="card-body">Video editing, social media asset creation, listing photo processing, content repurposing, thumbnail and carousel design, caption drafting</p>
    </div>
    <div class="service-card" style="text-align:center">
      <div class="card-title">Production Coordinator</div>
      <p class="card-body" style="font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem">Logistics & Operations</p>
      <p class="card-body">Shoot scheduling, equipment coordination, crew management, location scouting, file management, delivery workflows, quality control</p>
    </div>
  </div>

  <div class="highlight fade-in">
    <p>"Every other Forbes member globally outsources production to agencies. We bring it in-house through Voyager at preferential rates because of equity alignment. That is a competitive advantage, not a complication."</p>
  </div>
</section>

<hr class="full-divider">

<!-- SECTION 7: STRUCTURE -->
<section id="structure">
  <span class="section-number">07</span>
  <div class="fade-in">
    <div class="eyebrow">Partnership Structure</div>
    <h2 class="section-title">How It <em>Works</em></h2>
    <p class="section-body">The relationship between Voyager Visual and Forbes Global Properties SA is structured as an exclusive service partnership. Voyager invoices Forbes SA on a monthly retainer for marketing director services. Production is quoted and billed separately per project. Both services are delivered by the same equity-aligned team, ensuring total continuity, accountability, and brand consistency.</p>
  </div>

  <table class="scope-table fade-in" style="margin-top:3rem">
    <thead>
      <tr>
        <th style="width:35%">Component</th>
        <th style="width:35%">Structure</th>
        <th style="width:30%">Accountability</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="label">Marketing Director Services</td>
        <td>Monthly retainer invoice from Voyager Visual to Forbes SA</td>
        <td>Quarterly KPIs, defined deliverables, ongoing reporting</td>
      </tr>
      <tr>
        <td class="label">Film & Content Production</td>
        <td>Per-project quotes or production retainer. Billed separately through Voyager Visual</td>
        <td>Project briefs, delivery timelines, quality standards per Forbes spec</td>
      </tr>
      <tr>
        <td class="label">Exclusivity</td>
        <td>Voyager Visual services Forbes SA exclusively. No competing retainer clients</td>
        <td>Contractual exclusivity clause with defined terms</td>
      </tr>
      <tr>
        <td class="label">Equity Alignment</td>
        <td>Cameron holds equity in Forbes SA. Keegan holds equity in Voyager. Both parties aligned on long-term success</td>
        <td>Vesting schedules, KPI milestones, annual review</td>
      </tr>
      <tr>
        <td class="label">IP & Brand Protection</td>
        <td>Forbes systems (Notion, CRM, content calendar) remain with Forbes. Production assets and Voyager brand remain with Voyager</td>
        <td>Documented in partnership agreement. Standard creative industry terms</td>
      </tr>
    </tbody>
  </table>
</section>

<hr class="full-divider">

<!-- CTA -->
<section class="cta-section">
  <div class="fade-in">
    <div class="eyebrow">The Opportunity</div>
    <h2>South Africa's Most Extraordinary Homes<br>Deserve <em>the World's Finest Presentation</em></h2>
    <div class="gold-rule" style="margin:3rem auto"></div>
    <p class="section-body" style="margin:0 auto;text-align:center;max-width:550px">Voyager Visual exists to ensure that every property represented by Forbes Global Properties South Africa is presented with a level of craft, strategy, and storytelling that matches the prestige of the Forbes name.</p>
  </div>
</section>

<footer>
  <p>Voyager Visual &nbsp;×&nbsp; South Africa | Forbes Global Properties &nbsp;&nbsp;·&nbsp;&nbsp; Confidential &nbsp;&nbsp;·&nbsp;&nbsp; March 2026</p>
</footer>

<script>
// Scroll nav
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>{nav.classList.toggle('scrolled',window.scrollY>80)});

// Intersection observer for fade-ins
const obs=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target)}})
},{threshold:.15,rootMargin:'0px 0px -50px 0px'});
document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));
</script>
</body>
</html>
